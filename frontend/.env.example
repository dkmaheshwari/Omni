# Frontend to backend API base
VITE_API_URL=http://localhost:5051/api
VITE_SOCKET_URL=http://localhost:5051
# Set to true only if intentionally using an ephemeral Cloudflare tunnel URL in production.
VITE_ALLOW_TUNNEL_URL=false

# Firebase Web config (required for frontend auth)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
